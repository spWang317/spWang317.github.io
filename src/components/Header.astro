---
import type { Locale } from '../data/content';
import { profile } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
const base = import.meta.env.BASE_URL; // 끝에 / 포함
const koHome = base;
const enHome = `${base}en/`;
const otherHref = lang === 'ko' ? enHome : koHome;

const nav = [
  { href: '#about', key: 'nav.about' as const },
  { href: '#research', key: 'nav.research' as const },
  { href: '#books', key: 'nav.books' as const },
  { href: '#projects', key: 'nav.projects' as const },
  { href: '#teaching', key: 'nav.teaching' as const },
  { href: '#education', key: 'nav.education' as const },
  { href: '#contact', key: 'nav.contact' as const },
];
---

<header class="hd">
  <div class="wrap hd-inner">
    <a href={lang === 'ko' ? koHome : enHome} class="brand">{profile.name[lang]}</a>

    <nav class="nav" aria-label="Sections">
      {nav.map((n) => <a href={n.href}>{tr(n.key)}</a>)}
    </nav>

    <div class="tools">
      <a class="tool lang" href={otherHref} aria-label="Switch language">{tr('lang.label')}</a>
      <button class="tool" id="theme-btn" type="button" aria-label={tr('theme.toggle')}>
        <svg class="ico sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" fill="currentColor" />
          <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="12" y1="2.5" x2="12" y2="5" /><line x1="12" y1="19" x2="12" y2="21.5" />
            <line x1="2.5" y1="12" x2="5" y2="12" /><line x1="19" y1="12" x2="21.5" y2="12" />
            <line x1="5" y1="5" x2="6.8" y2="6.8" /><line x1="17.2" y1="17.2" x2="19" y2="19" />
            <line x1="19" y1="5" x2="17.2" y2="6.8" /><line x1="6.8" y1="17.2" x2="5" y2="19" />
          </g>
        </svg>
        <svg class="ico moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M20 14.5A8.5 8.5 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5Z" fill="currentColor" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-btn');
  btn?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch (e) {}
  });
</script>

<style>
  .hd {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .hd-inner {
    display: flex;
    align-items: center;
    gap: 18px;
    height: 62px;
  }
  .brand {
    font-weight: 750;
    font-size: 1.04rem;
    letter-spacing: -0.02em;
    margin-right: auto;
  }
  .nav { display: flex; gap: 18px; }
  .nav a {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 550;
    white-space: nowrap;
    transition: color 0.18s var(--ease);
  }
  .nav a:hover { color: var(--text); }
  .tools { display: flex; align-items: center; gap: 8px; }
  .tool {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    min-width: 36px;
    padding: 0 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .tool:hover { border-color: var(--accent); transform: translateY(-1px); }
  .ico { display: none; }
  :global(:root[data-theme='light']) .sun { display: block; }
  :global(:root[data-theme='dark']) .moon { display: block; }

  @media (max-width: 860px) {
    .nav { display: none; }
    .brand { font-size: 1rem; }
  }
</style>
