---
import type { Locale } from '../data/content';
import { books } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
const base = import.meta.env.BASE_URL;
---

<section id="books">
  <div class="wrap">
    <div class="reveal">
      <span class="eyebrow">{tr('eyebrow.books')}</span>
      <h2 class="section-title">{tr('section.books')}</h2>
      <p class="section-sub">{tr('section.books.sub')}</p>
    </div>

    <div class="grid">
      {books.map((b, i) => {
        const Tag = b.href ? 'a' : 'div';
        const initial = b.title[lang].trim().charAt(0) || '·';
        return (
          <Tag
            class="card reveal"
            style={`transition-delay:${i * 70}ms`}
            href={b.href || undefined}
            target={b.href ? '_blank' : undefined}
            rel={b.href ? 'noopener' : undefined}
          >
            <div class="cover">
              {b.cover
                ? <img src={`${base}${b.cover}`} alt={b.title[lang]} loading="lazy" />
                : <span class="placeholder">{initial}</span>}
            </div>
            <div class="info">
              <span class="role-tag">{b.role[lang]}</span>
              <h3>{b.title[lang]}</h3>
              {b.authors && <p class="authors">{b.authors[lang]}</p>}
              <p class="meta">
                {b.publisher[lang]}
                {b.year && <> · {b.year}</>}
              </p>
              {b.summary && <p class="summary">{b.summary[lang]}</p>}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .card {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: var(--shadow);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease),
      border-color 0.3s var(--ease), opacity 0.7s var(--ease);
  }
  a.card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .cover {
    aspect-ratio: 2 / 3;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--accent-soft), color-mix(in srgb, var(--accent) 30%, transparent));
    display: grid;
    place-items: center;
    border: 1px solid var(--border);
  }
  .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .placeholder {
    font-size: 2rem;
    font-weight: 750;
    color: var(--accent);
    opacity: 0.85;
  }
  .info { display: flex; flex-direction: column; }
  .role-tag {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 3px 9px;
    border-radius: 999px;
    margin-bottom: 8px;
  }
  .card h3 {
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .authors { color: var(--text); font-size: 0.88rem; margin-top: 4px; font-weight: 550; }
  .meta { color: var(--muted); font-size: 0.83rem; margin-top: 2px; }
  .summary { color: var(--muted); font-size: 0.9rem; margin-top: 10px; line-height: 1.5; }
</style>
