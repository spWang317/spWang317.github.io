---
import type { Locale } from '../data/content';
import { teaching } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);

// 강사/초청강연 강조용 클래스
function badgeClass(role?: string) {
  if (!role) return 'badge';
  if (role.includes('강사') || role.includes('Lecturer')) return 'badge badge-primary';
  if (role.includes('초청') || role.includes('Invited')) return 'badge badge-accent';
  return 'badge';
}
---

<section id="teaching" class="sec-teaching">
  <div class="wrap">
    <div class="reveal">
      <span class="eyebrow">{tr('eyebrow.teaching')}</span>
      <h2 class="section-title">{tr('section.teaching')}</h2>
    </div>
    <ul class="list">
      {teaching.map((c, i) => (
        <li class="row reveal" style={`transition-delay:${i * 50}ms`}>
          <div class="term">{c.term[lang]}</div>
          <div class="body">
            {c.role && (
              <span class={badgeClass(c.role[lang])}>{c.role[lang]}</span>
            )}
            <p class="course">{c.course[lang]}</p>
            <p class="org">{c.org[lang]}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .sec-teaching { background: var(--bg-alt); }
  .list { list-style: none; display: flex; flex-direction: column; }
  .row {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid var(--border);
  }
  .row:first-child { border-top: none; }
  .term {
    color: var(--accent);
    font-weight: 650;
    font-size: 0.92rem;
    letter-spacing: -0.01em;
  }
  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--surface);
    margin-bottom: 8px;
  }
  .badge-primary {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }
  .badge-accent {
    color: var(--accent);
    background: var(--accent-soft);
    border-color: transparent;
  }
  .course {
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.45;
  }
  .org {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 3px;
  }

  @media (max-width: 620px) {
    .row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
