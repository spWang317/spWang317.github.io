---
import type { Locale } from '../data/content';
import { research } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="research" class="sec-research">
  <div class="wrap">
    <div class="reveal">
      <span class="eyebrow">{tr('eyebrow.research')}</span>
      <h2 class="section-title">{tr('section.research')}</h2>
      <p class="section-sub">{tr('section.research.sub')}</p>
    </div>
    <div class="grid">
      {research.map((r, i) => {
        const Tag = r.href ? 'a' : 'div';
        return (
          <Tag
            class="card reveal"
            style={`transition-delay:${i * 70}ms`}
            href={r.href || undefined}
            target={r.href ? '_blank' : undefined}
            rel={r.href ? 'noopener' : undefined}
          >
            <h3>{r.title[lang]}</h3>
            <p>{r.summary[lang]}</p>
            <div class="tags">
              {r.tags.map((tg) => <span class="chip">{tg}</span>)}
            </div>
            {r.href && <span class="arrow" aria-hidden="true">→</span>}
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  .sec-research { background: var(--bg-alt); }
  .grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
  .card {
    position: relative;
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 26px 24px;
    box-shadow: var(--shadow);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease),
      border-color 0.3s var(--ease), opacity 0.7s var(--ease);
  }
  a.card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .card h3 {
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 9px;
  }
  .card p { color: var(--muted); font-size: 0.95rem; margin-bottom: 16px; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .arrow {
    position: absolute;
    top: 22px;
    right: 22px;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }
  a.card:hover .arrow { opacity: 1; transform: none; }
</style>
