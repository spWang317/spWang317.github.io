---
import type { Locale } from '../data/content';
import { profile } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
const social = profile.links.filter((l) => l.href.startsWith('http'));
---

<section id="contact">
  <div class="wrap inner reveal">
    <span class="eyebrow">{tr('eyebrow.contact')}</span>
    <h2 class="section-title">{tr('section.contact')}</h2>
    <p class="body">{tr('contact.body')}</p>
    <p class="email-text">wangsp0317 at kaist.ac.kr</p>
    {social.length > 0 && (
      <div class="social">
        {social.map((l) => (
          <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .inner { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .body { color: var(--muted); font-size: 1.08rem; margin: 4px 0 28px; max-width: 40ch; }
  .big { font-size: 1rem; padding: 13px 24px; }
  .email-text {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--accent);
    margin: 0;
  }
  .social { display: flex; gap: 22px; margin-top: 26px; }
  .social a {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 600;
    transition: color 0.18s var(--ease);
  }
  .social a:hover { color: var(--accent); }
</style>
