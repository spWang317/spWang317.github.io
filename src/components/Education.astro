---
import type { Locale } from '../data/content';
import { education } from '../data/content';
import { t } from '../i18n/ui';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="education" class="sec-edu">
  <div class="wrap">
    <div class="reveal">
      <span class="eyebrow">{tr('eyebrow.education')}</span>
      <h2 class="section-title">{tr('section.education')}</h2>
    </div>
    <ol class="list">
      {education.map((e, i) => (
        <li class="row reveal" style={`transition-delay:${i * 60}ms`}>
          <div class="period">{e.period}</div>
          <div class="body">
            <p class="degree">{e.degree[lang]}</p>
            <p class="org">{e.org[lang]}</p>
            {e.thesis && (
              <p class="thesis">
                <span class="label">{lang === 'ko' ? '논문' : 'Thesis'}</span>
                <em>{e.thesis[lang]}</em>
              </p>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .sec-edu { background: var(--bg-alt); }
  .list { list-style: none; display: flex; flex-direction: column; }
  .row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid var(--border);
  }
  .row:first-child { border-top: none; }
  .period {
    color: var(--accent);
    font-weight: 650;
    font-size: 0.92rem;
    letter-spacing: -0.01em;
  }
  .degree { font-weight: 700; letter-spacing: -0.01em; }
  .org { color: var(--muted); font-size: 0.92rem; margin-top: 3px; }
  .thesis {
    color: var(--muted);
    font-size: 0.86rem;
    margin-top: 9px;
    line-height: 1.55;
  }
  .label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 7px;
    border-radius: 6px;
    margin-right: 8px;
    vertical-align: 1px;
  }
  .thesis em { font-style: normal; }

  @media (max-width: 620px) {
    .row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
